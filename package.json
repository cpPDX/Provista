{
  "name": "grocery-tracker",
  "version": "1.0.0",
  "description": "Browser-based grocery price tracker with households, auth, and inventory management",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
